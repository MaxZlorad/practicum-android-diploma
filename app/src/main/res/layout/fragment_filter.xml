<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Тулбар -->
    <include
        android:id="@+id/include_toolbar"
        layout="@layout/toolbar_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/left_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="@dimen/dp_16" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/right_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="@dimen/dp_16" />

    <View
        android:id="@+id/background_title_industry"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_48"
        android:layout_marginTop="@dimen/dp_16"

        app:layout_constraintStart_toStartOf="@+id/left_guideline"
        app:layout_constraintEnd_toEndOf="@+id/right_guideline"
        app:layout_constraintTop_toBottomOf="@+id/include_toolbar" />

    <TextView
        android:id="@+id/industry_hint_unselected"
        style="@style/TextAppearance.Regular16"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_48"
        android:gravity="center_vertical"
        android:text="@string/industry"
        android:visibility="visible"
        app:layout_constraintStart_toStartOf="@+id/left_guideline"
        app:layout_constraintEnd_toEndOf="@+id/right_guideline"
        app:layout_constraintTop_toTopOf="@+id/background_title_industry" />

    <TextView
        android:id="@+id/industry_hint_selected"
        style="@style/TextAppearance.Regular12"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_16"
        android:gravity="center_vertical"
        android:text="@string/industry"
        android:layout_marginTop="@dimen/dp_6"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@+id/left_guideline"
        app:layout_constraintEnd_toEndOf="@+id/right_guideline"
        app:layout_constraintTop_toTopOf="@+id/background_title_industry" />

    <TextView
        android:id="@+id/industry_selected"
        style="@style/TextAppearance.Regular16"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_19"
        android:gravity="center_vertical"
        android:hint="IT"
        android:textColorHint="@color/black"
        android:textColor="@color/black"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@+id/left_guideline"
        app:layout_constraintEnd_toEndOf="@+id/right_guideline"
        app:layout_constraintTop_toBottomOf="@+id/industry_hint_selected" />

    <ImageButton
        android:id="@+id/btn_select_industry"
        android:layout_width="@dimen/dp_48"
        android:layout_height="@dimen/dp_48"
        android:backgroundTint="@color/white"
        android:contentDescription="@string/industry"
        android:src="@drawable/ic_arrow_forward_24"
        android:layout_marginEnd="@dimen/dp_4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/background_title_industry"
        app:tint="@color/black" />

    <View
        android:id="@+id/background_title"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_51"
        android:background="@drawable/edit_text_field"
        android:layout_marginTop="@dimen/dp_24"
        app:layout_constraintEnd_toStartOf="@+id/right_guideline"
        app:layout_constraintStart_toStartOf="@+id/left_guideline"
        app:layout_constraintTop_toBottomOf="@+id/background_title_industry" />

    <TextView
        android:id="@+id/salary_expected"
        style="@style/TextAppearance.Regular12"
        android:layout_width="@dimen/dp_0"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:text="@string/salary_expected"
        android:textColor="@color/gray"
        android:layout_marginTop="@dimen/dp_8"
        android:layout_marginStart="@dimen/dp_16"
        android:layout_marginEnd="@dimen/dp_16"
        app:layout_constraintStart_toStartOf="@+id/background_title"
        app:layout_constraintEnd_toEndOf="@+id/background_title"
        app:layout_constraintTop_toTopOf="@+id/background_title" />

    <EditText
        android:id="@+id/enter_amount"
        style="@style/SearchTextField"
        android:layout_width="@dimen/dp_0"
        android:layout_height="wrap_content"
        android:autofillHints="none"
        android:gravity="center_vertical"
        android:hint="@string/enter_amount"
        android:imeOptions="actionDone"
        android:inputType="number"
        android:lines="1"
        android:layout_marginStart="@dimen/dp_16"
        android:layout_marginEnd="@dimen/dp_16"
        app:layout_constraintEnd_toStartOf="@+id/right_guideline"
        app:layout_constraintStart_toStartOf="@+id/left_guideline"
        app:layout_constraintTop_toBottomOf="@+id/salary_expected" />

    <ImageButton
        android:id="@+id/button_salary_clear"
        android:layout_width="@dimen/dp_24"
        android:layout_height="@dimen/dp_24"
        android:layout_marginTop="@dimen/dp_14"
        android:layout_marginEnd="@dimen/dp_16"
        android:background="@null"
        android:src="@drawable/ic_clear"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@+id/background_title"
        app:layout_constraintTop_toTopOf="@+id/background_title" />

    <TextView
        android:id="@+id/do_not_show_without_salary"
        style="@style/TextAppearance.Regular16"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_48"
        android:gravity="center_vertical"
        android:text="@string/do_not_show_without_salary"
        android:textColor="@color/black"
        android:layout_marginTop="@dimen/dp_30"
        app:layout_constraintEnd_toEndOf="@+id/right_guideline"
        app:layout_constraintStart_toStartOf="@+id/left_guideline"
        app:layout_constraintTop_toBottomOf="@+id/background_title" />

    <ImageButton
        android:id="@+id/checkbox_salary"
        android:layout_width="@dimen/dp_48"
        android:layout_height="@dimen/dp_48"
        android:backgroundTint="@color/white"
        android:contentDescription="@string/industry"
        android:src="@drawable/ic_checkbox_off_24"
        android:layout_marginEnd="@dimen/dp_4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/do_not_show_without_salary" />

    <Button
        android:id="@+id/button_apply"
        style="@style/CustomButtonStyle"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_59"
        android:text="@string/apply"
        android:textColor="@color/white"
        android:layout_marginBottom="@dimen/dp_8"
        android:padding="@dimen/dp_0"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@+id/button_cancel"
        app:layout_constraintEnd_toEndOf="@+id/right_guideline"
        app:layout_constraintStart_toStartOf="@+id/left_guideline" />

    <Button
        android:id="@+id/button_cancel"
        style="@style/CustomButtonStyle"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_59"
        android:text="@string/reset"
        android:textColor="@color/red"
        android:background="@android:color/transparent"
        android:layout_marginBottom="@dimen/dp_24"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/right_guideline"
        app:layout_constraintStart_toStartOf="@+id/left_guideline" />

</androidx.constraintlayout.widget.ConstraintLayout>
